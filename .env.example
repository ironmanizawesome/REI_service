# 공용 환경변수 예시 — 복사해서 .env 로 사용

# LLM / 임베딩 (RAG 챗봇)
OPENAI_API_KEY=sk-...
# 모델 기본값(코드): 생성 gpt-5.4, 임베딩 text-embedding-3-large
# 바꾸려면 아래 주석 해제
# OPENAI_CHAT_MODEL=gpt-5.4
# OPENAI_EMBED_MODEL=text-embedding-3-large

# 텔레그램 봇
TELEGRAM_BOT_TOKEN=

# PSIS 농약안전정보시스템 OpenAPI
PSIS_API_KEY=

# 백엔드 API 주소 (웹에서 참조)
VITE_API_BASE_URL=http://localhost:8000
